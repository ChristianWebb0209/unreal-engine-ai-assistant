# Copy to ".env" in this repo root and fill secrets. ".env" is gitignored.
# Repo scripts call scripts/Import-RepoDotenv.ps1 so the editor child process inherits these vars.
#
# After changing OPENAI_* or provider settings, push them into the plugin JSON:
#   .\scripts\sync-unreal-ai-from-dotenv.ps1
# (loads repo .env by default; or pass -EnvFile path)

# ------------------------------------------------------------------------------
# Unreal Engine
# ------------------------------------------------------------------------------
UE_ENGINE_ROOT=C:\Program Files\Epic Games\UE_5.7

# Skip blueprint formatter git sync in build-editor.ps1 (1 or true)
UE_SKIP_BLUEPRINT_FORMATTER_SYNC=

# ------------------------------------------------------------------------------
# LLM provider -> plugin_settings.json (Editor does NOT read these; run sync script).
# `providers[]` / models in JSON support many vendors; OPENAI_* below are convenience env names for sync only.
# ------------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ------------------------------------------------------------------------------
# Harness (read inside UnrealEditor.exe; scripts set defaults if vars are empty)
# ------------------------------------------------------------------------------
# Max ms game thread waits for harness sink (10000-900000). Should exceed HTTP timeout + tool work.
UNREAL_AI_HARNESS_SYNC_WAIT_MS=180000

# HTTP request timeout for chat-completions calls in seconds (plugin clamps to 5-30; default in transport is 30).
UNREAL_AI_HTTP_REQUEST_TIMEOUT_SEC=30

# 0 = non-streaming chat/completions (often matches fast in-editor behavior with large tool lists). 1 = stream. Empty = Editor bStreamLlmChat.
# UNREAL_AI_LLM_STREAM=0

# 1 = send tools=[] on agent turns (fast HTTP sanity check only; model cannot call editor tools).
# UNREAL_AI_HARNESS_OMIT_TOOLS=1

# Tool payload: core pack + extras; and native vs dispatch surface.
# dispatch = one small `unreal_ai_dispatch` tool in HTTP tools[] + compact id/summary index in system message (recommended for timeouts).
# native = one function tool per catalog tool with full JSON Schema in tools[] (large).
# Headed scripts default to dispatch + core + EXTRA when unset.
# UNREAL_AI_TOOL_SURFACE=native
# UNREAL_AI_TOOL_PACK=full
# UNREAL_AI_TOOL_PACK_EXTRA=asset_create,blueprint_compile

# Cap agent LLM rounds per turn when set (plugin + scripts)
UNREAL_AI_HARNESS_MAX_LLM_ROUNDS=4

# 1 = dump context_window_*.txt during runs; 0 = off
UNREAL_AI_HARNESS_DUMP_CONTEXT=0

# Usually unset (scripts set per step): UNREAL_AI_HARNESS_MESSAGE_FILE, UNREAL_AI_HARNESS_THREAD_GUID, UNREAL_AI_HARNESS_AGENT_MODE

# ------------------------------------------------------------------------------
# Optional / tooling
# ------------------------------------------------------------------------------
# Set by `tests/run-unreal-ai-tests.ps1` when possible; you normally leave this unset
# GIT_COMMIT=

# Headless tool routing tests; `tests/test-tools.ps1` sets this when needed
# UNREAL_AI_TOOL_PROMPTS_FIXTURE=