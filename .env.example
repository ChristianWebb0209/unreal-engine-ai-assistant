# Copy to ".env" in the repo root (gitignored). Scripts load it via scripts/Import-RepoDotenv.ps1.
# Supported keys below (plus optional UE_REPO_UPROJECT). Other names are ignored unless a script documents them.
#
# After changing OPENAI_*, run: .\scripts\sync-unreal-ai-from-dotenv.ps1
# to refresh %LOCALAPPDATA%\UnrealAiEditor\settings\plugin_settings.json.

UE_ENGINE_ROOT=C:\Program Files\Epic Games\UE_5.7
# Optional: path to the .uproject to build/open when more than one exists at the repo root, or for a non-standard layout (relative to repo root or absolute).
# UE_REPO_UPROJECT=MyGame.uproject
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
