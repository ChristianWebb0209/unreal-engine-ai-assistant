{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/unreal-ai/context_workflow.schema.json",
  "title": "Unreal AI context workflow manifest",
  "type": "object",
  "required": ["schema_version", "suite_id", "workflow_id", "steps"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "suite_id": { "type": "string", "minLength": 1 },
    "workflow_id": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "thread_strategy": { "type": "string", "enum": ["reuse_guid"], "default": "reuse_guid" },
    "default_mode": { "type": "string", "enum": ["agent", "ask", "orchestrate"], "default": "agent" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "message_file"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "message_file": { "type": "string", "minLength": 1 },
          "mode": { "type": "string", "enum": ["agent", "ask", "orchestrate"] },
          "notes": { "type": "string" },
          "expect_context_hints": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
