# Policy: version only plugin sources under Plugins/UnrealAiEditor plus repo docs/scripts/tests/README.
# Never commit engine outputs, local game project trees (Blank), or sibling plugins in Plugins/.

# --- Repo root (Blank / UE project — local only) ---
/.vs/
/.vsconfig
/agent-and-tool-requirements.md
/Binaries/
/blank.sln
/blank.uproject
/Config/
/Content/
/DerivedDataCache/
/Intermediate/
/Saved/
/Source/
/Build/

# Visual Studio / Xcode
*.sln
*.opensdf
*.sdf
*.suo
*.VC.db
*.xcodeproj
*.xcworkspace

# Only UnrealAiEditor is part of this repo; other folders under Plugins/ (e.g. UnrealBlueprintFormatter) stay local.
/Plugins/*
!/Plugins/UnrealAiEditor/
!/Plugins/UnrealAiEditor/**

# --- Plugins: generated / local build outputs ---
Plugins/**/Intermediate/
Plugins/**/Binaries/
Plugins/**/Saved/
Plugins/**/DerivedDataCache/
Plugins/**/Build/
Plugins/**/.vs/
Plugins/**/*.sln
Plugins/**/*.opensdf
Plugins/**/*.sdf
Plugins/**/*.suo
Plugins/**/*.VC.db
Plugins/**/*.VC.db-*
Plugins/**/*.opendb

# Visual Studio / Rider / general IDE noise (outside ignored project trees)
*.VC.db-*
*.opendb
*.user
*.userosscache
*.rsuser
.idea/
*.DotSettings.user

# Secrets — never commit API keys or local env files
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db

# Cursor / local dev artifacts
/.cursor/

# Unreal/automation local output folders
/BuildOut/
/tests-failed.txt

# Tests: track only .py and .ps1 (ignore JSON fixtures, run outputs, logs, etc.)
/tests/**
!/tests/**/
!/tests/**/*.py
!/tests/**/*.ps1
# Re-ignore paths that became visible because parent dirs were un-ignored for traversal
/tests/out/
/tests/long-running-tests/runs/
/tests/**/*.json
/tests/**/*.jsonl

# Optional local scratch (untracked copies of scripts, experiments)
/local/

# Python
**/__pycache__/


/tools/