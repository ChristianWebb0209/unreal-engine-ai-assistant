{
  "tools": [
    {
      "tool_id": "blueprint_compile",
      "summary": "Blueprint Builder sub-turn only (agent_surfaces: blueprint_builder; not on default main Agent). Compile a Blueprint and return diagnostics. Use after blueprint_graph_patch, blueprint_graph_patch, or other graph edits to validate/fix compile state; not for graph discovery (use blueprint_get_graph_summary or blueprint_graph_introspect). Use format_graphs to run in-process graph layout on script graphs before compile when graphs should be laid out.",
      "category": "blueprints",
      "tags": [
        "blueprint"
      ],
      "tier": "standard",
      "modes": {
        "ask": false,
        "agent": true,
        "plan": true
      },
      "agent_surfaces": [
        "blueprint_builder"
      ],
      "context_selector": {
        "priority": 50,
        "always_include_in_core_pack": false,
        "embedding_hint": null,
        "blueprint_builder_core": true
      },
      "parameters": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "blueprint_path": {
            "type": "string"
          },
          "format_graphs": {
            "type": "boolean",
            "description": "When true, run bundled graph layout on all non-empty ubergraph, function, and macro graphs before compiling."
          },
          "focused": {
            "type": "boolean",
            "description": "After success, open and foreground this Blueprint in the editor."
          }
        },
        "required": [
          "blueprint_path"
        ]
      },
      "side_effects": "compile",
      "permission": "write",
      "ue_entry_points": "FKismetEditorUtilities::CompileBlueprint",
