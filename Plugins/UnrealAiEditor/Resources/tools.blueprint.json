    {
      "tool_id": "blueprint_set_component_default",
      "summary": "Blueprint Builder sub-turn only (not default main Agent). Set one reflected property on a named Actor component on the Blueprint class default (CDO), then compile. Use for gameplay tuning that lives on component defaults (e.g. CharacterMovement.JumpZVelocity) instead of asset_apply_properties on the UBlueprint asset object. Requires blueprint_path under /Game, component name (e.g. CharacterMovement), property name (e.g. JumpZVelocity), and value (number/bool/string per property type). Does not replace blueprint_graph_patch / blueprint_graph_patch for EventGraph logic.",
      "category": "blueprints",
      "tags": [
        "blueprint",
        "defaults",
        "component"
      ],
      "tier": "standard",
      "modes": {
        "ask": false,
        "agent": true,
        "plan": true
      },
      "agent_surfaces": [
        "blueprint_builder"
      ],
      "context_selector": {
        "priority": 52,
        "always_include_in_core_pack": false,
        "embedding_hint": null,
        "blueprint_builder_core": true
      },
      "parameters": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "blueprint_path": {
            "type": "string",
            "description": "Blueprint asset object path under /Game (e.g. /Game/Blueprints/MyCharacter.MyCharacter)."
          },
          "component": {
            "type": "string",
            "description": "Component name on the class default, e.g. CharacterMovement (matches ACharacter movement component)."
          },
          "property": {
            "type": "string",
            "description": "Property name on the component class (e.g. JumpZVelocity)."
          },
          "value": {
            "description": "JSON value: number for floats/ints, bool, or string (enums, names, ExportText for exotic types)."
          }
        },
        "required": [
          "blueprint_path",
          "component",
          "property",
          "value"
        ]
      },
      "side_effects": "compile",
      "permission": "write",
      "ue_entry_points": "AActor CDO component property write, FKismetEditorUtilities::CompileBlueprint",
      "threading": "game_thread",
      "failure_modes": [
        "Blueprint generated class is not an Actor (only Actor-based BPs have instanced component defaults on CDO).",
        "component not found on class default, or property not editable on component instance."
      ],
      "doc_links": [],
      "status": "implemented"
    },
