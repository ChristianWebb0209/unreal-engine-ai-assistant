      "failure_modes": [],
      "doc_links": [
        "https://dev.epicgames.com/documentation/en-us/unreal-engine/blueprints-visual-scripting-in-unreal-engine"
      ],
      "status": "implemented"
    },
    {
      "tool_id": "blueprint_graph_patch",
      "summary": "Blueprint Builder sub-turn only (agent_surfaces: blueprint_builder; not on default main Agent). Atomic: if any op fails, the transaction is cancelled (nothing persists; applied_partial is always []). Failure JSON: status patch_errors (or patch_validate_errors when validate_only), errors[], error_codes[], failed_op_index, optional failed_op or failed_op_json snippet, suggested_correct_call (error-kind-specific: e.g. list_pins for bad links, Character Jump/Landed pattern for event_override / missing CallFunction — not a generic IfThenElse default), note. Anti-pattern: T3D placeholders __UAI_G_NNNNNN__ — use guid:UUID from blueprint_graph_introspect or patch_id from this batch. For very large op lists, use ops_json_path (project-relative UTF-8 file: root JSON array of ops) under Saved/ or harness_step/ — mutually exclusive with inline ops[]. Resolver preflight repairs create_node k2_class aliases, event_override hoisting, Character Jump/Landed call targets, connect link_from/link_to and split from_node+from_pin into from/to, add_variable type aliases; resolver_audit may list graph_patch_repairs. Primary UE 5.7 graph mutator: ops[] or ops_json_path on blueprint_path (/Game) and graph_name. create_node (UK2Node), create_comment, connect, break_link, splice_on_link, set_pin_default, add_variable, remove_node, move_node. auto_layout defaults true with layout_scope patched_nodes; full_graph reformats entire script graph. Formatter follows Editor Preferences → Plugins → Unreal AI Editor → Blueprint Formatting.",
      "category": "blueprints",
      "tags": [
        "blueprint",
        "graph",
        "write",
        "k2"
      ],
      "tier": "standard",
      "modes": {
        "ask": false,
        "agent": true,
        "plan": true
      },
      "agent_surfaces": [
        "blueprint_builder"
      ],
      "context_selector": {
        "priority": 74,
        "always_include_in_core_pack": false,
        "embedding_hint": null,
        "blueprint_builder_core": true
      },
      "parameters": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "blueprint_path": {
            "type": "string",
            "minLength": 1,
            "description": "Blueprint asset object path under /Game only (e.g. /Game/Folder/MyBP.MyBP)."
          },
          "graph_name": {
            "type": "string",
            "description": "Script graph to edit (default: EventGraph). Use export/summary to list function or macro graphs."
          },
          "compile": {
            "type": "boolean",
            "description": "When true (default), recompile the Blueprint after ops. For full compiler_messages[], follow with blueprint_compile."
          },
          "auto_layout": {
            "type": "boolean",
            "description": "When true (default), run bundled graph layout after ops succeed. Set false to preserve manual node positions for this patch."
          },
          "layout_scope": {
            "type": "string",
            "enum": [
              "patched_nodes",
              "full_graph"
            ],
            "description": "patched_nodes: layout only nodes created in this patch (create_node/create_comment), then translate cluster using node bounding boxes and push any overlapping non-patch script nodes right (AABB + gap). full_graph: LayoutEntireGraph on the script graph—use only when an explicit reformat is intended."
          },
          "ops_json_path": {
            "type": "string",
            "minLength": 1,
            "description": "Project-relative path to a UTF-8 JSON file whose root value is an array of patch op objects (same schema as ops[]). Must start with Saved/ or harness_step/. Mutually exclusive with non-empty inline ops[]; use for very large patches that should not be embedded in the tool-call stream."
          },
          "ops": {
            "type": "array",
            "minItems": 0,
            "description": "Ordered operations (non-empty unless ops_json_path is set). NodeRef for connect/break_link/splice: patch_id from this batch, guid:uuid, or bare node_guid from blueprint_graph_introspect. `self` is not a graph node—use blueprint_graph_list_pins for VariableSet Target pins.",
            "items": {
              "oneOf": [
                {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "op": {
                      "type": "string",
                      "enum": [
                        "create_node"
                      ]
                    },
                    "patch_id": {
                      "type": "string",
                      "minLength": 1,
                      "description": "Local id for NodeRef in connect/set_pin_default within this ops list (e.g. n1)."
                    },
                    "k2_class": {
                      "type": "string",
                      "minLength": 1,
                      "description": "UK2Node class object path, e.g. /Script/BlueprintGraph.K2Node_IfThenElse. Use K2Node_ prefix in /Script paths (not UK2Node_). Bare K2Node_* is accepted and expanded to /Script/BlueprintGraph.* (K2Node_Enhanced* → /Script/InputBlueprintNodes.*). Integer math/compare has no K2Node_IntLess/IntAdd — use K2Node_CallFunction + /Script/Engine.KismetMathLibrary + Less_IntInt / Add_IntInt / etc. Do not put node_guid on create_node (schema rejects it). Do not use __UAI_G_* in connect refs (T3D-only)."
                    },
                    "event_name": {
                      "type": "string",
                      "description": "For K2Node_CustomEvent: function name (also custom_event_name or custom_event.name or name)."
